{
  "publisher": "micaiguai",
  "name": "micaiguai-open-npm",
  "displayName": "Open Npm In Vscode",
  "version": "1.0.9",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "description": "",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/micaiguai/open-npm#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/micaiguai/open-npm"
  },
  "bugs": {
    "url": "https://github.com/micaiguai/open-npm/issues"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "assets/icon.png",
  "files": [
    "LICENSE.md",
    "assets/*",
    "dist/*"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [],
    "configuration": {
      "type": "object",
      "title": "open-npm",
      "properties": {}
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --external vscode",
    "dev": "nr build --watch --sourcemap",
    "prepare": "nr update",
    "update": "vscode-ext-gen --output src/generated/meta.ts",
    "lint": "eslint .",
    "vscode:prepublish": "nr build",
    "publish": "vsce publish --no-dependencies",
    "pack": "vsce package --no-dependencies",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && nr publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@antfu/ni": "^23.3.1",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.4",
    "esno": "^4.8.0",
    "pnpm": "^10.33.4",
    "reactive-vscode": "^0.2.22",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vscode-ext-gen": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
